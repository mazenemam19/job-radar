{
  "compilerOptions": {
    "lib": ["es2022"],
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".scripts-out",
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["scripts/**/*.ts", "src/lib/**/*.ts", "src/types/**/*.ts"]
}
