# .env.local
# Copy this file to .env.local and fill in your values.

# ── Email notifications  (optional to recieve email with recent jobs) ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
# Gmail: Settings → Security → App Passwords → 16-char code, no spaces, no dashes
SMTP_PASS=xxxxxxxxxxxxxxxxxxxx
NOTIFY_TO=recipient@email.com

# ── Cron protection ────────────────────────────────────────────────────────
# Used to protect POST /api/cron in production. Generate with: openssl rand -hex 32
CRON_SECRET=your_random_secret_string_here

# ── Supabase V1 ────────────────────────────────────────────────────
SUPABASE_URL=YOUR_SUPABASE_URL_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# ── Supabase V2 ────────────────────────────────────────────────────
# Identical to SUPABASE_URL (needed for @supabase/ssr inside the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# The safe public anon key from Supabase Settings -> API
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Gemini AI (optional for extra filteration) ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Set this to your local dev / production url for email routing ─────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Optional: Number of day to send salary reminder
REMIND_AFTER_DAYS=28