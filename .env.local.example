# .env.local
# Copy this file to .env.local and fill in your values.
BLOB_READ_WRITE_TOKEN=
# ── Email notifications ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
# Gmail: Settings → Security → App Passwords → 16-char code, no spaces, no dashes
SMTP_PASS=xxxxxxxxxxxxxxxxxxxx
NOTIFY_TO=recipient@email.com

# ── Cron protection ────────────────────────────────────────────────────────
# Used to protect POST /api/cron in production. Generate with: openssl rand -hex 32
CRON_SECRET=your_random_secret_string_here

# ── Vercel Blob Storage ────────────────────────────────────────────────────
# Get this from your Vercel Project Dashboard → Storage → Create Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── App URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
