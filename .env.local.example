# https://www.themuse.com/developers/api/v2
THEMUSE_API_KEY=your_key_here

# Gmail SMTP — use App Password (16 chars, no spaces, no dashes)
# Enable at: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=abcdabcdabcdabcd

# Who receives job alerts
NOTIFY_TO=your.email@gmail.com

# Protect the /api/cron endpoint — any random string
CRON_SECRET=replace-with-a-random-secret-string

# Your app URL (for email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
