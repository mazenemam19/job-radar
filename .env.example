# ─── Adzuna API (Free tier — sign up at https://developer.adzuna.com) ───────────
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# ─── Reed API (Free — sign up at https://www.reed.co.uk/developers/jobseeker) ──
REED_API_KEY=your_reed_api_key

# ─── Email Notifications (Gmail example) ────────────────────────────────────────
# For Gmail: enable 2FA and generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_gmail_app_password
NOTIFY_TO=your.email@gmail.com

# ─── App ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Secret for protecting the /api/cron endpoint (use any random string)
CRON_SECRET=change_me_to_a_random_secret
