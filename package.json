{
  "name": "job-radar",
  "version": "2.0.0-alpha",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report",
    "cron": "ts-node -r tsconfig-paths/register --project tsconfig.scripts.json src/scripts/cron.ts",
    "salary-reminders": "ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/send-salary-reminders.ts",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.0",
    "dompurify": "^3.4.11",
    "gsap": "^3.15.0",
    "next": "14.2.35",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.1",
    "eslint-config-next": "14",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.3.1",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
